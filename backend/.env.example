## EduMate-AI backend env (example)
## Copy to `backend/.env` and fill in real values.

# App
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Database
# Local quickstart option:
DATABASE_URL=sqlite:///./edumate.db
# Example Postgres:
# DATABASE_URL=postgresql://user:pass@localhost:5432/edumate

# OpenAI (required for workflows)
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7
OPENAI_REQUEST_TIMEOUT=120.0

# AWS S3 (required for document upload with current storage service)
AWS_REGION=us-east-1
AWS_S3_BUCKET=replace_me
AWS_ACCESS_KEY_ID=replace_me
AWS_SECRET_ACCESS_KEY=replace_me

# If you want local dev without startup bucket checks (upload may still fail if misconfigured)
S3_VERIFY_BUCKET_ON_INIT=false

# Firebase Admin (required to verify frontend Firebase ID tokens)
# Option A: set GOOGLE_APPLICATION_CREDENTIALS to a service account JSON file path.
# Option B: provide the fields below.
FIREBASE_PROJECT_ID=replace_me
FIREBASE_PRIVATE_KEY_ID=replace_me
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace_me\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=replace_me@replace_me.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=replace_me

# Optional monitoring
SENTRY_DSN=
WANDB_PROJECT=edumate-ai
WANDB_API_KEY=

# Optional diagnostics endpoint security (only used if enabled)
ENABLE_WORKFLOW_METRICS_ENDPOINT=false
WORKFLOW_METRICS_MAX_SAMPLES=2000
METRICS_ADMIN_KEY=

