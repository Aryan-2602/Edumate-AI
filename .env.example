## EduMate-AI Environment Configuration (Example)
## --------------------------------------------------
## Copy values into:
## - backend/.env        (FastAPI reads this)
## - frontend/.env.local (Next.js reads this)
##
## Never commit real secrets. This file is a template only.
##
## Put real keys ONLY in backend/.env or frontend/.env.local (both are gitignored).
## If you ever pasted a real key here, revoke/rotate it in the provider dashboard.


######################################################
# 🚀 QUICK START (Minimum to run backend locally)
######################################################
# Required:
# - DATABASE_URL
# - OPENAI_API_KEY (set the real value in backend/.env — not in this file)
#
# Then run:
# cd backend
# uvicorn app.main:app --reload

DATABASE_URL=sqlite:///./edumate.db
OPENAI_API_KEY=changeme_set_in_backend_dot_env


######################################################
# 🌐 FRONTEND (Next.js)
######################################################

# Backend API URL
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Firebase client config (for frontend auth)
NEXT_PUBLIC_FIREBASE_API_KEY=replace_me
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=replace_me.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=replace_me
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=replace_me.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=replace_me
NEXT_PUBLIC_FIREBASE_APP_ID=replace_me
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=


######################################################
# ⚙️ BACKEND (FastAPI)
######################################################

# App settings
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Database (override if not using SQLite above)
# DATABASE_URL=postgresql://user:pass@localhost:5432/edumate


######################################################
# 🤖 LLM CONFIGURATION
######################################################

# OpenAI settings
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7
OPENAI_REQUEST_TIMEOUT=120.0


######################################################
# ☁️ AWS S3 (Production / Document Storage)
######################################################

# Required for document upload in production
# For local development, you may skip S3 setup,
# but upload endpoints may fail if not configured.

AWS_REGION=us-east-1
AWS_S3_BUCKET=replace_me
AWS_ACCESS_KEY_ID=replace_me
AWS_SECRET_ACCESS_KEY=replace_me

# Disable bucket validation during startup (useful for local dev)
S3_VERIFY_BUCKET_ON_INIT=false


######################################################
# 🔐 FIREBASE ADMIN (Backend Auth)
######################################################

# Required only if using authenticated endpoints
# For local testing, this can be bypassed if backend allows it

# Option A: Use service account file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Option B: Inline credentials
FIREBASE_PROJECT_ID=replace_me
FIREBASE_PRIVATE_KEY_ID=replace_me
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace_me\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=replace_me@replace_me.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=replace_me


######################################################
# 📊 MONITORING (Optional)
######################################################

# Error tracking
SENTRY_DSN=

# Experiment tracking
WANDB_PROJECT=edumate-ai
WANDB_API_KEY=


######################################################
# 🧪 ADVANCED (Diagnostics / Internal)
######################################################

# Enable workflow metrics endpoint (for debugging / benchmarking)
ENABLE_WORKFLOW_METRICS_ENDPOINT=false

# Max number of samples stored for metrics
WORKFLOW_METRICS_MAX_SAMPLES=2000

# Optional admin key for protected metrics endpoints
METRICS_ADMIN_KEY=